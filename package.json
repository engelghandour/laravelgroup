{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:3000": "vite --port 3000",
    "dev:4000": "vite --port 4000",
    "serve": "php artisan serve --host=127.0.0.1 --port=8000",
    "serve:9000": "php artisan serve --host=127.0.0.1 --port=9000",
    "serve:3001": "php artisan serve --host=127.0.0.1 --port=3001",
    "dev:full": "concurrently -k -n php,vite -c red,cyan \"npm:serve\" \"npm:dev\"",
    "dev:custom": "concurrently -k -n php,vite -c red,cyan \"npm:serve:9000\" \"npm:dev:3000\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.4"
    }
}
